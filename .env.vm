# VM config: all storage under /data (large disk)
# Copy to .env when running on the Ubuntu VM:
#   cp .env.vm .env

LOG_LEVEL=INFO
LOG_FILE="/data/vectordb_bench/logs/vectordb_bench.log"

# Datasets (can be many GB) - must be on large disk
DATASET_LOCAL_DIR="/data/vectordb_bench/dataset"

# Benchmark results
RESULTS_LOCAL_DIR="/data/vectordb_bench/results"

# Full docker logs for each auto-provisioned DB container (saved after stop, before rm) — large disk, for VM debugging
SAVE_PROVISIONED_CONTAINER_LOGS=1
PROVISIONED_CONTAINER_LOGS_DIR="/data/vectordb_bench/container_logs"

# Config files (optional; leave unset to use repo defaults)
CONFIG_LOCAL_DIR="/data/vectordb_bench/config-files"

# ClickHouse data on NVMe (avoids using /dev/root)
CLICKHOUSE_DATA_DIR="/data/vectordb_bench/clickhouse_data"
# Vector similarity + high concurrency: keep per-query threads low (raise only if single-client and stable).
CLICKHOUSE_QUERY_MAX_THREADS=2
# Raise SQL text limit for batched update mode with high-dimensional vectors.
CLICKHOUSE_MAX_QUERY_SIZE=1048576
# Optional: enable ClickHouse query profiler settings for flamegraph collection.
# Sampling adds overhead; keep disabled unless debugging.
# CLICKHOUSE_ENABLE_FLAMEGRAPH=1
# CLICKHOUSE_FLAMEGRAPH_REAL_TIME_PERIOD_NS=10000000
# CLICKHOUSE_FLAMEGRAPH_CPU_TIME_PERIOD_NS=10000000
# Auto-provisioned ClickHouse: enable system.trace_log via mounted config snippet (needed for chdg trace-log flamegraphs).
# Auto-enabled when CLICKHOUSE_ENABLE_FLAMEGRAPH=1, or force explicitly:
# CLICKHOUSE_ENABLE_TRACE_LOG=1
# CLICKHOUSE_TRACE_LOG_FLUSH_INTERVAL_MS=7500
# Optional Docker profiling permissions for deeper diagnostics inside container:
# CLICKHOUSE_DOCKER_ENABLE_PROFILE_PERMISSIONS=1

# Milvus Docker standalone data on NVMe (embedded etcd + local storage)
MILVUS_DATA_DIR="/data/vectordb_bench/milvus_data"
MILVUS_EXTRA_READINESS_WAIT_SEC=15
MILVUS_LOAD_RETRY_MAX_ATTEMPTS=50
MILVUS_LOAD_RETRY_INTERVAL_SEC=3

# Qdrant Docker storage on NVMe (mounts to /qdrant/storage)
QDRANT_DATA_DIR="/data/vectordb_bench/qdrant_storage"
# REST timeout for qdrant-client create_collection (seconds). Bump on slow disks if you see disconnect errors.
QDRANT_CLIENT_TIMEOUT_SEC=180
# Scope CPU/memory/disk metrics to the DB's own Docker container (via `docker stats`) instead of the whole VM.
MONITOR_DB_CONTAINER_STATS=1
# Explicit Qdrant container name/id to monitor; empty = auto-detect the running qdrant/qdrant container.
QDRANT_CONTAINER=""

# PgVector / Postgres data on NVMe (PGDATA)
PGVECTOR_DATA_DIR="/data/vectordb_bench/pgvector_data"
# Pin image tag (:latest is often missing on Docker Hub); try pg17 if you need a newer Postgres
PGVECTOR_DOCKER_IMAGE=pgvector/pgvector:pg16
# /dev/shm for Postgres parallel CREATE INDEX (DSM); Docker default ~64m causes "No space left on device"
PGVECTOR_DOCKER_SHM_SIZE=16g

# Large VM: no Docker memory cap on auto-provisioned DBs (Milvus needs host RAM; --cpus still from profile)
PROVISION_DOCKER_MEMORY_UNLIMITED=1
# Clear host DB data dirs before each auto-provision start and after teardown (dataset dir untouched). Default in app is true.
PROVISION_CLEAR_HOST_DATA_AFTER_RUN=1
# Fix root-owned bind-mount data so rmtree succeeds: docker chown first, then sudo -n chown if needed.
PROVISION_CLEAR_HOST_DATA_DOCKER_CHOWN_FALLBACK=1
PROVISION_CLEAR_HOST_DATA_SUDO_CHOWN=1

# Pause between auto-provisioned DB teardown and next container start (seconds)
POST_PROVISION_TEARDOWN_DELAY_SEC=300

# Skip psutil in process cleanup (avoids PermissionError on restricted VMs)
VDB_SKIP_PSUTIL=1
