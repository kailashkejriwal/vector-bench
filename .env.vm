# VM config: all storage under /mnt/disks (large disk)
# Copy to .env when running on the Ubuntu VM:
#   cp .env.vm .env

LOG_LEVEL=INFO
LOG_FILE="/mnt/disks/vectordb_bench/logs/vectordb_bench.log"

# Datasets (can be many GB) - must be on large disk
DATASET_LOCAL_DIR="/mnt/disks/vectordb_bench/dataset"

# Benchmark results
RESULTS_LOCAL_DIR="/mnt/disks/vectordb_bench/results"

# Full docker logs for each auto-provisioned DB container (saved after stop, before rm) — large disk, for VM debugging
SAVE_PROVISIONED_CONTAINER_LOGS=1
PROVISIONED_CONTAINER_LOGS_DIR="/mnt/disks/vectordb_bench/container_logs"

# Config files (optional; leave unset to use repo defaults)
CONFIG_LOCAL_DIR="/mnt/disks/vectordb_bench/config-files"

# ClickHouse data on NVMe (avoids using /dev/root)
CLICKHOUSE_DATA_DIR="/mnt/disks/vectordb_bench/clickhouse_data"

# Milvus Docker standalone data on NVMe (embedded etcd + local storage)
MILVUS_DATA_DIR="/mnt/disks/vectordb_bench/milvus_data"
MILVUS_EXTRA_READINESS_WAIT_SEC=15
MILVUS_LOAD_RETRY_MAX_ATTEMPTS=50
MILVUS_LOAD_RETRY_INTERVAL_SEC=3

# Qdrant Docker storage on NVMe (mounts to /qdrant/storage)
QDRANT_DATA_DIR="/mnt/disks/vectordb_bench/qdrant_storage"
# REST timeout for qdrant-client create_collection (seconds). Bump on slow disks if you see disconnect errors.
QDRANT_CLIENT_TIMEOUT_SEC=180

# PgVector / Postgres data on NVMe (PGDATA)
PGVECTOR_DATA_DIR="/mnt/disks/vectordb_bench/pgvector_data"
# Pin image tag (:latest is often missing on Docker Hub); try pg17 if you need a newer Postgres
PGVECTOR_DOCKER_IMAGE=pgvector/pgvector:pg16
# /dev/shm for Postgres parallel CREATE INDEX (DSM); Docker default ~64m causes "No space left on device"
PGVECTOR_DOCKER_SHM_SIZE=16g

# Large VM: no Docker memory cap on auto-provisioned DBs (Milvus needs host RAM; --cpus still from profile)
PROVISION_DOCKER_MEMORY_UNLIMITED=1

# Pause between auto-provisioned DB teardown and next container start (seconds)
POST_PROVISION_TEARDOWN_DELAY_SEC=300

# Skip psutil in process cleanup (avoids PermissionError on restricted VMs)
VDB_SKIP_PSUTIL=1
