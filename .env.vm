# VM config: all storage under /mnt/disks (large disk)
# Copy to .env when running on the Ubuntu VM:
#   cp .env.vm .env

LOG_LEVEL=INFO
LOG_FILE="/mnt/disks/vectordb_bench/logs/vectordb_bench.log"

# Datasets (can be many GB) - must be on large disk
DATASET_LOCAL_DIR="/mnt/disks/vectordb_bench/dataset"

# Benchmark results
RESULTS_LOCAL_DIR="/mnt/disks/vectordb_bench/results"

# Config files (optional; leave unset to use repo defaults)
CONFIG_LOCAL_DIR="/mnt/disks/vectordb_bench/config-files"

# Concurrency & scalability (optional)
# NUM_CONCURRENCY=1,5,10,20,30,40,60,80
# CONCURRENCY_DURATION=30
# CONCURRENCY_TIMEOUT=3600
# SEARCH_STAGES=[0.1, 0.2, 0.5, 0.8]
# STREAMING_CONCURRENCIES=[5, 10, 20]
