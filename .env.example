LOG_LEVEL=INFO
LOG_FILE="logs/vectordb_bench.log"
# TIMEZONE=

# NUM_PER_BATCH=
# DEFAULT_DATASET_URL=

# Dataset download location (can be many GB)
DATASET_LOCAL_DIR="/tmp/vectordb_bench/dataset"

# Benchmark results (default: vectordb_bench/results/)
# RESULTS_LOCAL_DIR=

# Filter test distributions (comma-separated). Empty = use all. Reduces resource use.
# LABEL_FILTER_PERCENTAGES=0.001,0.5
# INT_FILTER_RATES=0.01,0.99

# Concurrency (performance tests): concurrencies to test, duration per level (s), slot timeout (s)
# NUM_CONCURRENCY=1,5,10,20,30,40,60,80
# CONCURRENCY_DURATION=30
# CONCURRENCY_TIMEOUT=3600

# Scalability (streaming tests): search stages (JSON) and concurrencies (JSON)
# SEARCH_STAGES=[0.1, 0.2, 0.5, 0.8]
# STREAMING_CONCURRENCIES=[5, 10, 20]

# On VM with large disk at /mnt/disks: cp .env.vm .env
# DROP_OLD = True
