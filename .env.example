LOG_LEVEL=INFO
LOG_FILE="logs/vectordb_bench.log"
# First Streamlit port for `python -m vectordb_bench` (if busy, next free port is used). Override with VDB_STREAMLIT_PORT.
# VDB_STREAMLIT_PORT=8509
# TIMEZONE=

# NUM_PER_BATCH=
# DEFAULT_DATASET_URL=

# Dataset download location (can be many GB)
DATASET_LOCAL_DIR="/tmp/vectordb_bench/dataset"

# Benchmark results (default: vectordb_bench/results/)
# RESULTS_LOCAL_DIR=

# Save full `docker logs` for each auto-provisioned DB container after stop, before rm (for debugging).
# SAVE_PROVISIONED_CONTAINER_LOGS=1
# Directory for those logs (default: under RESULTS_LOCAL_DIR/container_logs).
# PROVISIONED_CONTAINER_LOGS_DIR=/mnt/disks/vectordb_bench/container_logs

# ClickHouse data dir on host (e.g. NVMe). When set, mounts to /var/lib/clickhouse.
# CLICKHOUSE_DATA_DIR=/mnt/disks/vectordb_bench/clickhouse_data
# Cap max_threads + merge_tree_max_threads on the native client (load + vector search). Low default avoids
# "Too many threads" in vector_similarity index under NUM_CONCURRENCY. Try 1 if needed; 0 = server defaults.
# CLICKHOUSE_QUERY_MAX_THREADS=2

# Milvus (Docker standalone) data dir. When set, mounts to /var/lib/milvus.
# MILVUS_DATA_DIR=/mnt/disks/vectordb_bench/milvus_data
# Extra sleep after Milvus TCP is open so querynode registers (avoids resource group / currentNodeNum=0 on LoadCollection). 0=off.
# MILVUS_EXTRA_READINESS_WAIT_SEC=10
# Retry col.load() when query nodes are not ready yet (attempt count and seconds between tries).
# MILVUS_LOAD_RETRY_MAX_ATTEMPTS=40
# MILVUS_LOAD_RETRY_INTERVAL_SEC=3

# Qdrant (Docker) storage dir. When set, mounts to /qdrant/storage.
# QDRANT_DATA_DIR=/mnt/disks/vectordb_bench/qdrant_storage
# qdrant-client REST timeout in seconds (default 120). Raise if create_collection hits "Server disconnected" on slow I/O.
# QDRANT_CLIENT_TIMEOUT_SEC=180
# PgVector / Postgres (Docker) PGDATA. When set, mounts to /var/lib/postgresql/data in the container.
# PGVECTOR_DATA_DIR=/mnt/disks/vectordb_bench/pgvector_data
# PgVector image tag (Hub often has no :latest). Examples: pgvector/pgvector:pg16, pgvector/pgvector:pg17
# PGVECTOR_DOCKER_IMAGE=pgvector/pgvector:pg16
# PgVector docker --shm-size (default 8g). Postgres DSM for parallel CREATE INDEX lives on /dev/shm; Docker default is ~64m.
# Increase if maintenance_work_mem in the case is higher than ~8GB; set empty to omit (not recommended).
# PGVECTOR_DOCKER_SHM_SIZE=8g

# Idle seconds between different DB workloads (auto→auto, auto→manual, manual→manual when DB changes).
# Runs after Docker confirms removal for auto teardown. Use a long value (e.g. 600+) for visible gaps on Grafana.
# POST_PROVISION_TEARDOWN_DELAY_SEC=600
# Optional: run sync(1) before each quiet window (disk metrics may settle slightly).
# POST_PROVISION_SYNC_BEFORE_COOLDOWN=1
# Max seconds to poll docker inspect until the container disappears after rm (default 120).
# DOCKER_CONTAINER_REMOVAL_WAIT_TIMEOUT_SEC=180
# Do not pass docker --memory (DB can use host RAM until OOM at VM level). Still uses --cpus from profile.
# PROVISION_DOCKER_MEMORY_UNLIMITED=1
# Before each auto-provision run and after teardown, delete host CLICKHOUSE/MILVUS/QDRANT/PGVECTOR data dirs
# (not DATASET_LOCAL_DIR). Default true. Set 0 to keep DB files. Post-teardown clear skipped when leave_container_running=True.
# PROVISION_CLEAR_HOST_DATA_AFTER_RUN=0
# If rmtree hits permission denied, retry after `sudo -n chown -R` to the bench user (Docker bind mounts
# are often root-owned). Default true. Set 0 to skip; configure NOPASSWD for chown on DB data dirs if needed.
# PROVISION_CLEAR_HOST_DATA_SUDO_CHOWN=0

# Filter test distributions (comma-separated). Empty = use all. Reduces resource use.
# LABEL_FILTER_PERCENTAGES=0.001,0.5
# INT_FILTER_RATES=0.01,0.99

# On VM with large disk at /mnt/disks: cp .env.vm .env
# DROP_OLD = True