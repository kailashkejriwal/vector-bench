LOG_LEVEL=INFO
LOG_FILE="logs/vectordb_bench.log"
# TIMEZONE=

# NUM_PER_BATCH=
# DEFAULT_DATASET_URL=

# Dataset download location (can be many GB)
DATASET_LOCAL_DIR="/tmp/vectordb_bench/dataset"

# Benchmark results (default: vectordb_bench/results/)
# RESULTS_LOCAL_DIR=

# Save full `docker logs` for each auto-provisioned DB container after stop, before rm (for debugging).
# SAVE_PROVISIONED_CONTAINER_LOGS=1
# Directory for those logs (default: under RESULTS_LOCAL_DIR/container_logs).
# PROVISIONED_CONTAINER_LOGS_DIR=/mnt/disks/vectordb_bench/container_logs

# ClickHouse data dir on host (e.g. NVMe). When set, mounts to /var/lib/clickhouse.
# CLICKHOUSE_DATA_DIR=/mnt/disks/vectordb_bench/clickhouse_data
# Limit server threads per vector search (avoids "Too many threads" / vector similarity index errors under load).
# Default in app is 8 if unset. Set to 0 to use ClickHouse server defaults only (may fail with high NUM_CONCURRENCY).
# CLICKHOUSE_QUERY_MAX_THREADS=4

# Milvus (Docker standalone) data dir. When set, mounts to /var/lib/milvus.
# MILVUS_DATA_DIR=/mnt/disks/vectordb_bench/milvus_data

# Qdrant (Docker) storage dir. When set, mounts to /qdrant/storage.
# QDRANT_DATA_DIR=/mnt/disks/vectordb_bench/qdrant_storage

# Idle seconds between different DB workloads (auto→auto, auto→manual, manual→manual when DB changes).
# Runs after Docker confirms removal for auto teardown. Use a long value (e.g. 600+) for visible gaps on Grafana.
# POST_PROVISION_TEARDOWN_DELAY_SEC=600
# Optional: run sync(1) before each quiet window (disk metrics may settle slightly).
# POST_PROVISION_SYNC_BEFORE_COOLDOWN=1
# Max seconds to poll docker inspect until the container disappears after rm (default 120).
# DOCKER_CONTAINER_REMOVAL_WAIT_TIMEOUT_SEC=180

# Filter test distributions (comma-separated). Empty = use all. Reduces resource use.
# LABEL_FILTER_PERCENTAGES=0.001,0.5
# INT_FILTER_RATES=0.01,0.99

# On VM with large disk at /mnt/disks: cp .env.vm .env
# DROP_OLD = True
